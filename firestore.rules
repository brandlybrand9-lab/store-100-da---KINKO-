rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Function to check if the user is an admin.
    // Normally we'd use a trusted database collection to store admins.
    // For this applet, let's assume specific email handles admin, or any signed-in user for simplicity since it's an applet, 
    // but the system prompt says "Bootstrapped Admin: Include User email from runtime as an admin if the app has an admin feature."
    // User Email: brandlybrand9@gmail.com
    function isAdmin() {
      // Pour autoriser n'importe quel compte créé à gérer les produits :
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'nameFr', 'nameAr', 'category', 'image', 'price']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nameFr is string && data.nameFr.size() <= 200 &&
             data.nameAr is string && data.nameAr.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.image is string && data.image.size() <= 1048576 &&
             data.price is number &&
             (!('descriptionFr' in data.keys()) || (data.descriptionFr is string && data.descriptionFr.size() <= 1000)) &&
             (!('descriptionAr' in data.keys()) || (data.descriptionAr is string && data.descriptionAr.size() <= 1000)) &&
             (!('deleted' in data.keys()) || data.deleted is bool);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'items', 'totalPrice', 'name', 'phone', 'city', 'address', 'status', 'createdAt']) &&
             data.id is string &&
             data.items is list &&
             data.totalPrice is number &&
             data.name is string &&
             data.phone is string &&
             data.city is string &&
             data.address is string &&
             data.status in ["pending", "delivered", "cancelled"] &&
             data.createdAt is number;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() &&
                    isValidId(productId) &&
                    isValidProduct(incoming()) &&
                    incoming().id == productId;
      
      allow update: if isAdmin() &&
                    isValidId(productId) &&
                    isValidProduct(incoming());
                    
      allow delete: if isAdmin() && isValidId(productId);
    }

    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if isValidId(orderId) &&
                       isValidOrder(incoming()) &&
                       incoming().id == orderId;
      allow update: if isAdmin() &&
                       isValidId(orderId) &&
                       isValidOrder(incoming());
      allow delete: if isAdmin() && isValidId(orderId);
    }
  }
}
